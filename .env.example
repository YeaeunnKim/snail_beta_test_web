# Backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# App
NEXT_PUBLIC_APP_NAME=스네일 사장님

# OpenAPI docs (optional)
NEXT_PUBLIC_API_DOCS_URL=https://poi82999.github.io/snail_backend_specification/

# --- 개발용 자동 로그인 (선택) ---
# 1로 켜면 토큰이 없을 때 시드 사장님 계정으로 자동 로그인해 로그인 화면을 건너뛴다.
# 운영 빌드에서는 켜지 말 것. 시드 비밀번호는 백엔드 docker-compose의 SEED_OWNER_PASSWORD와 일치해야 한다.
NEXT_PUBLIC_DEV_AUTOLOGIN=0
NEXT_PUBLIC_DEV_OWNER_EMAIL=owner1@seed.snail.app
NEXT_PUBLIC_DEV_OWNER_PASSWORD=devpass1234
